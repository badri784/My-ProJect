        "hizbQuarter": 237,
        "sajda": false
      },
      {
        "number": 6000,
        "text": "إِرَمَ ذَاتِ ٱلۡعِمَادِ\n",
        "surah": {
          "number": 89,
          "name": "سُورَةُ الفَجۡرِ",
