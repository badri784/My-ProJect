        "hizbQuarter": 237,
        "sajda": false
      },
      {
        "number": 6001,
        "text": "ٱلَّتِی لَمۡ یُخۡلَقۡ مِثۡلُهَا فِی ٱلۡبِلَـٰدِ\n",
        "surah": {
          "number": 89,
