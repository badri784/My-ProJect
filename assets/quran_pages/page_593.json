        "hizbQuarter": 237,
        "sajda": false
      },
      {
        "number": 5997,
        "text": "وَٱلَّیۡلِ إِذَا یَسۡرِ\n",
        "surah": {
          "number": 89,
          "name": "سُورَةُ الفَجۡرِ",
