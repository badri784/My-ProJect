        "hizbQuarter": 237,
        "sajda": false
      },
      {
        "number": 5999,
        "text": "أَلَمۡ تَرَ كَیۡفَ فَعَلَ رَبُّكَ بِعَادٍ\n",
        "surah": {
          "number": 89,
          "name": "سُورَةُ الفَجۡرِ",
