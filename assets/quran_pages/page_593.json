        "hizbQuarter": 237,
        "sajda": false
      },
      {
        "number": 5998,
        "text": "هَلۡ فِی ذَ ٰ⁠لِكَ قَسَمࣱ لِّذِی حِجۡرٍ\n",
        "surah": {
          "number": 89,
