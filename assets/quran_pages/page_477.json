      },
      {
        "number": 4222,
        "text": "بَشِیرࣰا وَنَذِیرࣰا فَأَعۡرَضَ أَكۡثَرُهُمۡ فَهُمۡ لَا یَسۡمَعُونَ\n",
        "surah": {
          "number": 41,
