        "sajda": false
      },
      {
        "number": 961,
        "text": "فَلَنَقُصَّنَّ عَلَیۡهِم بِعِلۡمࣲۖ وَمَا كُنَّا غَاۤىِٕبِینَ\n",
        "surah": {
