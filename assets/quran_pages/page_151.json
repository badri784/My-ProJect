        "hizbQuarter": 61,
        "sajda": false
      },
      {
        "number": 958,
        "text": "وَكَم مِّن قَرۡیَةٍ أَهۡلَكۡنَـٰهَا فَجَاۤءَهَا بَأۡسُنَا بَیَـٰتًا أَوۡ هُمۡ قَاۤىِٕلُونَ\n",
        "surah": {
          "number": 7,
