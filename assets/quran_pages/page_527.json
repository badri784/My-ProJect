        "hizbQuarter": 211,
        "sajda": false
      },
      {
        "number": 4812,
        "text": "وَمَا لَهُم بِهِۦ مِنۡ عِلۡمٍۖ إِن یَتَّبِعُونَ إِلَّا ٱلظَّنَّۖ وَإِنَّ ٱلظَّنَّ لَا یُغۡنِی مِنَ ٱلۡحَقِّ شَیۡـࣰٔا\n",
        "surah": {
          "number": 53,
          "name": "سُورَةُ النَّجۡمِ",
          "englishName": "An-Najm",
          "englishNameTranslation": "The Star",
          "revelationType": "Meccan",
          "numberOfAyahs": 62
        },
        "numberInSurah": 28,
