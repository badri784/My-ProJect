    "ayahs": [
      {
        "number": 4811,
        "text": "إِنَّ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ لَیُسَمُّونَ ٱلۡمَلَـٰۤىِٕكَةَ تَسۡمِیَةَ ٱلۡأُنثَىٰ\n",
        "surah": {
          "number": 53,
          "name": "سُورَةُ النَّجۡمِ",
          "englishName": "An-Najm",
          "englishNameTranslation": "The Star",
          "revelationType": "Meccan",
