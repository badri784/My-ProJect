        "sajda": false
      },
      {
        "number": 2737,
        "text": "حَتَّىٰۤ إِذَاۤ أَخَذۡنَا مُتۡرَفِیهِم بِٱلۡعَذَابِ إِذَا هُمۡ یَجۡـَٔرُونَ\n",
        "surah": {
          "number": 23,
