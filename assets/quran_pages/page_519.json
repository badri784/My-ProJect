        "sajda": false
      },
      {
        "number": 4651,
        "text": "وَجَاۤءَتۡ كُلُّ نَفۡسࣲ مَّعَهَا سَاۤىِٕقࣱ وَشَهِیدࣱ\n",
        "surah": {
          "number": 50,
