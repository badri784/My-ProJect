        "sajda": false
      },
      {
        "number": 4650,
        "text": "وَنُفِخَ فِی ٱلصُّورِۚ ذَ ٰ⁠لِكَ یَوۡمُ ٱلۡوَعِیدِ\n",
        "surah": {
          "number": 50,
