        "sajda": false
      },
      {
        "number": 4647,
        "text": "إِذۡ یَتَلَقَّى ٱلۡمُتَلَقِّیَانِ عَنِ ٱلۡیَمِینِ وَعَنِ ٱلشِّمَالِ قَعِیدࣱ\n",
        "surah": {
          "number": 50,
          "name": "سُورَةُ قٓ",
          "englishName": "Qaaf",
          "englishNameTranslation": "The letter Qaaf",
