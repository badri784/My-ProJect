        "hizbQuarter": 122,
        "sajda": false
      },
      {
        "number": 2255,
        "text": "وَإِنِّی خِفۡتُ ٱلۡمَوَ ٰ⁠لِیَ مِن وَرَاۤءِی وَكَانَتِ ٱمۡرَأَتِی عَاقِرࣰا فَهَبۡ لِی مِن لَّدُنكَ وَلِیࣰّا\n",
        "surah": {
          "number": 19,
