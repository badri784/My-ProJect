        "sajda": false
      },
      {
        "number": 5710,
        "text": "یَوۡمَ یَقُومُ ٱلرُّوحُ وَٱلۡمَلَـٰۤىِٕكَةُ صَفࣰّاۖ لَّا یَتَكَلَّمُونَ إِلَّا مَنۡ أَذِنَ لَهُ ٱلرَّحۡمَـٰنُ وَقَالَ صَوَابࣰا\n",
        "surah": {
          "number": 78,
          "name": "سُورَةُ النَّبَإِ",
          "englishName": "An-Naba",
