        "hizbQuarter": 238,
        "sajda": false
      },
      {
        "number": 6077,
        "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعۡمَةࣲ تُجۡزَىٰۤ\n",
        "surah": {
          "number": 92,
          "name": "سُورَةُ اللَّيۡلِ",
          "englishName": "Al-Lail",
