        "hizbQuarter": 238,
        "sajda": false
      },
      {
        "number": 6076,
        "text": "ٱلَّذِی یُؤۡتِی مَالَهُۥ یَتَزَكَّىٰ\n",
        "surah": {
          "number": 92,
          "name": "سُورَةُ اللَّيۡلِ",
