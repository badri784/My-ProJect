        "hizbQuarter": 238,
        "sajda": false
      },
      {
        "number": 6078,
        "text": "إِلَّا ٱبۡتِغَاۤءَ وَجۡهِ رَبِّهِ ٱلۡأَعۡلَىٰ\n",
        "surah": {
          "number": 92,
