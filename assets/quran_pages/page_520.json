        "sajda": false
      },
      {
        "number": 4668,
        "text": "وَلَقَدۡ خَلَقۡنَا ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ وَمَا بَیۡنَهُمَا فِی سِتَّةِ أَیَّامࣲ وَمَا مَسَّنَا مِن لُّغُوبࣲ\n",
        "surah": {
          "number": 50,
