        "sajda": false
      },
      {
        "number": 4670,
        "text": "وَمِنَ ٱلَّیۡلِ فَسَبِّحۡهُ وَأَدۡبَـٰرَ ٱلسُّجُودِ\n",
        "surah": {
          "number": 50,
