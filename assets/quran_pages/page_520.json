        "sajda": false
      },
      {
        "number": 4669,
        "text": "فَٱصۡبِرۡ عَلَىٰ مَا یَقُولُونَ وَسَبِّحۡ بِحَمۡدِ رَبِّكَ قَبۡلَ طُلُوعِ ٱلشَّمۡسِ وَقَبۡلَ ٱلۡغُرُوبِ\n",
        "surah": {
          "number": 50,
          "name": "سُورَةُ قٓ",
          "englishName": "Qaaf",
