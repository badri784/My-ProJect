        "hizbQuarter": 208,
        "sajda": false
      },
      {
        "number": 4671,
        "text": "وَٱسۡتَمِعۡ یَوۡمَ یُنَادِ ٱلۡمُنَادِ مِن مَّكَانࣲ قَرِیبࣲ\n",
