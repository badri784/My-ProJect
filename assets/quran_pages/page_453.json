        "hizbQuarter": 181,
        "sajda": false
      },
      {
        "number": 3974,
        "text": "وَعَجِبُوۤا۟ أَن جَاۤءَهُم مُّنذِرࣱ مِّنۡهُمۡۖ وَقَالَ ٱلۡكَـٰفِرُونَ هَـٰذَا سَـٰحِرࣱ كَذَّابٌ\n",
        "surah": {
          "number": 38,
          "name": "سُورَةُ صٓ",
          "englishName": "Saad",
          "englishNameTranslation": "The letter Saad",
