        "hizbQuarter": 181,
        "sajda": false
      },
      {
        "number": 3980,
        "text": "أَمۡ لَهُم مُّلۡكُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَاۖ فَلۡیَرۡتَقُوا۟ فِی ٱلۡأَسۡبَـٰبِ\n",
        "surah": {
          "number": 38,
