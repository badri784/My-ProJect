        "sajda": false
      },
      {
        "number": 3973,
        "text": "كَمۡ أَهۡلَكۡنَا مِن قَبۡلِهِم مِّن قَرۡنࣲ فَنَادَوا۟ وَّلَاتَ حِینَ مَنَاصࣲ\n",
        "surah": {
          "number": 38,
          "name": "سُورَةُ صٓ",
          "englishName": "Saad",
