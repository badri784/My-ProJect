        "sajda": false
      },
      {
        "number": 3979,
        "text": "أَمۡ عِندَهُمۡ خَزَاۤىِٕنُ رَحۡمَةِ رَبِّكَ ٱلۡعَزِیزِ ٱلۡوَهَّابِ\n",
        "surah": {
          "number": 38,
