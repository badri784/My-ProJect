        "hizbQuarter": 181,
        "sajda": false
      },
      {
        "number": 3978,
        "text": "أَءُنزِلَ عَلَیۡهِ ٱلذِّكۡرُ مِنۢ بَیۡنِنَاۚ بَلۡ هُمۡ فِی شَكࣲّ مِّن ذِكۡرِیۚ بَل لَّمَّا یَذُوقُوا۟ عَذَابِ\n",
        "surah": {
          "number": 38,
