        "hizbQuarter": 181,
        "sajda": false
      },
      {
        "number": 3976,
        "text": "وَٱنطَلَقَ ٱلۡمَلَأُ مِنۡهُمۡ أَنِ ٱمۡشُوا۟ وَٱصۡبِرُوا۟ عَلَىٰۤ ءَالِهَتِكُمۡۖ إِنَّ هَـٰذَا لَشَیۡءࣱ یُرَادُ\n",
        "surah": {
          "number": 38,
          "name": "سُورَةُ صٓ",
          "englishName": "Saad",
          "englishNameTranslation": "The letter Saad",
