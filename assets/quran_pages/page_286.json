      {
        "number": 2072,
        "text": "سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ عَمَّا یَقُولُونَ عُلُوࣰّا كَبِیرࣰا\n",
        "surah": {
          "number": 17,
          "name": "سُورَةُ الإِسۡرَاءِ",
