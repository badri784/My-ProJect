        "sajda": false
      },
      {
        "number": 6139,
        "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ إِذَا زُلۡزِلَتِ ٱلۡأَرۡضُ زِلۡزَالَهَا\n",
        "surah": {
          "number": 99,
          "name": "سُورَةُ الزَّلۡزَلَةِ",
          "englishName": "Az-Zalzala",
