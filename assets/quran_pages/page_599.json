        "sajda": false
      },
      {
        "number": 6144,
        "text": "یَوۡمَىِٕذࣲ یَصۡدُرُ ٱلنَّاسُ أَشۡتَاتࣰا لِّیُرَوۡا۟ أَعۡمَـٰلَهُمۡ\n",
        "surah": {
