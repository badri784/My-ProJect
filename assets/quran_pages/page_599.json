        "hizbQuarter": 239,
        "sajda": false
      },
      {
        "number": 6142,
        "text": "یَوۡمَىِٕذࣲ تُحَدِّثُ أَخۡبَارَهَا\n",
        "surah": {
          "number": 99,
          "name": "سُورَةُ الزَّلۡزَلَةِ",
