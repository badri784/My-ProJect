        "hizbQuarter": 239,
        "sajda": false
      },
      {
        "number": 6143,
        "text": "بِأَنَّ رَبَّكَ أَوۡحَىٰ لَهَا\n",
        "surah": {
          "number": 99,
          "name": "سُورَةُ الزَّلۡزَلَةِ",
          "englishName": "Az-Zalzala",
