        "hizbQuarter": 239,
        "sajda": false
      },
      {
        "number": 6140,
        "text": "وَأَخۡرَجَتِ ٱلۡأَرۡضُ أَثۡقَالَهَا\n",
        "surah": {
          "number": 99,
          "name": "سُورَةُ الزَّلۡزَلَةِ",
