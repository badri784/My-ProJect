        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5252,
        "text": "فَٱعۡتَرَفُوا۟ بِذَنۢبِهِمۡ فَسُحۡقࣰا لِّأَصۡحَـٰبِ ٱلسَّعِیرِ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
