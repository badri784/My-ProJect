    "ayahs": [
      {
        "number": 5242,
        "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ تَبَـٰرَكَ ٱلَّذِی بِیَدِهِ ٱلۡمُلۡكُ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 1,
        "juz": 29,
        "manzil": 7,
        "page": 562,
