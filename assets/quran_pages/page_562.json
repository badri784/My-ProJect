        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5243,
        "text": "ٱلَّذِی خَلَقَ ٱلۡمَوۡتَ وَٱلۡحَیَوٰةَ لِیَبۡلُوَكُمۡ أَیُّكُمۡ أَحۡسَنُ عَمَلࣰاۚ وَهُوَ ٱلۡعَزِیزُ ٱلۡغَفُورُ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 2,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5244,
        "text": "ٱلَّذِی خَلَقَ سَبۡعَ سَمَـٰوَ ٰ⁠تࣲ طِبَاقࣰاۖ مَّا تَرَىٰ فِی خَلۡقِ ٱلرَّحۡمَـٰنِ مِن تَفَـٰوُتࣲۖ فَٱرۡجِعِ ٱلۡبَصَرَ هَلۡ تَرَىٰ مِن فُطُورࣲ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 3,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5245,
        "text": "ثُمَّ ٱرۡجِعِ ٱلۡبَصَرَ كَرَّتَیۡنِ یَنقَلِبۡ إِلَیۡكَ ٱلۡبَصَرُ خَاسِئࣰا وَهُوَ حَسِیرࣱ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 4,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5246,
        "text": "وَلَقَدۡ زَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَجَعَلۡنَـٰهَا رُجُومࣰا لِّلشَّیَـٰطِینِۖ وَأَعۡتَدۡنَا لَهُمۡ عَذَابَ ٱلسَّعِیرِ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 5,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5247,
        "text": "وَلِلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ عَذَابُ جَهَنَّمَۖ وَبِئۡسَ ٱلۡمَصِیرُ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 6,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5248,
        "text": "إِذَاۤ أُلۡقُوا۟ فِیهَا سَمِعُوا۟ لَهَا شَهِیقࣰا وَهِیَ تَفُورُ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 7,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5249,
        "text": "تَكَادُ تَمَیَّزُ مِنَ ٱلۡغَیۡظِۖ كُلَّمَاۤ أُلۡقِیَ فِیهَا فَوۡجࣱ سَأَلَهُمۡ خَزَنَتُهَاۤ أَلَمۡ یَأۡتِكُمۡ نَذِیرࣱ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 8,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5250,
        "text": "قَالُوا۟ بَلَىٰ قَدۡ جَاۤءَنَا نَذِیرࣱ فَكَذَّبۡنَا وَقُلۡنَا مَا نَزَّلَ ٱللَّهُ مِن شَیۡءٍ إِنۡ أَنتُمۡ إِلَّا فِی ضَلَـٰلࣲ كَبِیرࣲ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 9,
        "juz": 29,
        "manzil": 7,
        "page": 562,
        "ruku": 496,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5251,
        "text": "وَقَالُوا۟ لَوۡ كُنَّا نَسۡمَعُ أَوۡ نَعۡقِلُ مَا كُنَّا فِیۤ أَصۡحَـٰبِ ٱلسَّعِیرِ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 10,
