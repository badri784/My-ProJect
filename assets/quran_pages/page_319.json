        "hizbQuarter": 127,
        "sajda": false
      },
      {
        "number": 2454,
        "text": "فَیَذَرُهَا قَاعࣰا صَفۡصَفࣰا\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
