        "sajda": false
      },
      {
        "number": 2456,
        "text": "یَوۡمَىِٕذࣲ یَتَّبِعُونَ ٱلدَّاعِیَ لَا عِوَجَ لَهُۥۖ وَخَشَعَتِ ٱلۡأَصۡوَاتُ لِلرَّحۡمَـٰنِ فَلَا تَسۡمَعُ إِلَّا هَمۡسࣰا\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
