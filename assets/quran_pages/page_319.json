        "sajda": false
      },
      {
        "number": 2453,
        "text": "وَیَسۡـَٔلُونَكَ عَنِ ٱلۡجِبَالِ فَقُلۡ یَنسِفُهَا رَبِّی نَسۡفࣰا\n",
        "surah": {
          "number": 20,
