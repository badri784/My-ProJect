        "sajda": false
      },
      {
        "number": 2457,
        "text": "یَوۡمَىِٕذࣲ لَّا تَنفَعُ ٱلشَّفَـٰعَةُ إِلَّا مَنۡ أَذِنَ لَهُ ٱلرَّحۡمَـٰنُ وَرَضِیَ لَهُۥ قَوۡلࣰا\n",
        "surah": {
          "number": 20,
