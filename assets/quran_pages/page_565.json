        "hizbQuarter": 226,
        "sajda": false
      },
      {
        "number": 5292,
        "text": "فَتَنَادَوۡا۟ مُصۡبِحِینَ\n",
        "surah": {
          "number": 68,
          "name": "سُورَةُ القَلَمِ",
