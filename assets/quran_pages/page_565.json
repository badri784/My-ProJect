        "sajda": false
      },
      {
        "number": 5290,
        "text": "فَطَافَ عَلَیۡهَا طَاۤىِٕفࣱ مِّن رَّبِّكَ وَهُمۡ نَاۤىِٕمُونَ\n",
        "surah": {
          "number": 68,
