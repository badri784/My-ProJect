        "hizbQuarter": 151,
        "sajda": false
      },
      {
        "number": 3165,
        "text": "وَإِنَّكَ لَتُلَقَّى ٱلۡقُرۡءَانَ مِن لَّدُنۡ حَكِیمٍ عَلِیمٍ\n",
