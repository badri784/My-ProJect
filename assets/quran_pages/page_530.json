        "hizbQuarter": 212,
        "sajda": false
      },
      {
        "number": 4877,
        "text": "إِنَّاۤ أَرۡسَلۡنَا عَلَیۡهِمۡ صَیۡحَةࣰ وَ ٰ⁠حِدَةࣰ فَكَانُوا۟ كَهَشِیمِ ٱلۡمُحۡتَظِرِ\n",
        "surah": {
          "number": 54,
