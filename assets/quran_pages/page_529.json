    "ayahs": [
      {
        "number": 4853,
        "text": "خُشَّعًا أَبۡصَـٰرُهُمۡ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ كَأَنَّهُمۡ جَرَادࣱ مُّنتَشِرࣱ\n",
        "surah": {
          "number": 54,
          "name": "سُورَةُ القَمَرِ",
          "englishName": "Al-Qamar",
          "englishNameTranslation": "The Moon",
          "revelationType": "Meccan",
          "numberOfAyahs": 55
        },
        "numberInSurah": 7,
        "juz": 27,
        "manzil": 7,
        "page": 529,
