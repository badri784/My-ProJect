        "sajda": false
      },
      {
        "number": 4861,
        "text": "وَلَقَد تَّرَكۡنَـٰهَاۤ ءَایَةࣰ فَهَلۡ مِن مُّدَّكِرࣲ\n",
        "surah": {
          "number": 54,
