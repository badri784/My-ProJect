        "sajda": false
      },
      {
        "number": 4860,
        "text": "تَجۡرِی بِأَعۡیُنِنَا جَزَاۤءࣰ لِّمَن كَانَ كُفِرَ\n",
        "surah": {
          "number": 54,
          "name": "سُورَةُ القَمَرِ",
