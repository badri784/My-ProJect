        "hizbQuarter": 211,
        "sajda": false
      },
      {
        "number": 4854,
        "text": "مُّهۡطِعِینَ إِلَى ٱلدَّاعِۖ یَقُولُ ٱلۡكَـٰفِرُونَ هَـٰذَا یَوۡمٌ عَسِرࣱ\n",
        "surah": {
          "number": 54,
          "name": "سُورَةُ القَمَرِ",
          "englishName": "Al-Qamar",
          "englishNameTranslation": "The Moon",
          "revelationType": "Meccan",
          "numberOfAyahs": 55
        },
        "numberInSurah": 8,
