        "hizbQuarter": 212,
        "sajda": false
      },
      {
        "number": 4857,
        "text": "فَفَتَحۡنَاۤ أَبۡوَ ٰ⁠بَ ٱلسَّمَاۤءِ بِمَاۤءࣲ مُّنۡهَمِرࣲ\n",
        "surah": {
          "number": 54,
          "name": "سُورَةُ القَمَرِ",
          "englishName": "Al-Qamar",
          "englishNameTranslation": "The Moon",
