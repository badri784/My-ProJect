    "ayahs": [
      {
        "number": 5314,
        "text": "خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۖ وَقَدۡ كَانُوا۟ یُدۡعَوۡنَ إِلَى ٱلسُّجُودِ وَهُمۡ سَـٰلِمُونَ\n",
        "surah": {
          "number": 68,
          "name": "سُورَةُ القَلَمِ",
          "englishName": "Al-Qalam",
          "englishNameTranslation": "The Pen",
