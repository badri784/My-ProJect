        "hizbQuarter": 226,
        "sajda": false
      },
      {
        "number": 5319,
        "text": "فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلۡحُوتِ إِذۡ نَادَىٰ وَهُوَ مَكۡظُومࣱ\n",
        "surah": {
          "number": 68,
