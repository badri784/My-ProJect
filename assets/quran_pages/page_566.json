        "hizbQuarter": 226,
        "sajda": false
      },
      {
        "number": 5316,
        "text": "وَأُمۡلِی لَهُمۡۚ إِنَّ كَیۡدِی مَتِینٌ\n",
        "surah": {
          "number": 68,
          "name": "سُورَةُ القَلَمِ",
          "englishName": "Al-Qalam",
