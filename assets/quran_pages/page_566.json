        "hizbQuarter": 226,
        "sajda": false
      },
      {
        "number": 5318,
        "text": "أَمۡ عِندَهُمُ ٱلۡغَیۡبُ فَهُمۡ یَكۡتُبُونَ\n",
        "surah": {
          "number": 68,
          "name": "سُورَةُ القَلَمِ",
          "englishName": "Al-Qalam",
          "englishNameTranslation": "The Pen",
