        "hizbQuarter": 226,
        "sajda": false
      },
      {
        "number": 5317,
        "text": "أَمۡ تَسۡـَٔلُهُمۡ أَجۡرࣰا فَهُم مِّن مَّغۡرَمࣲ مُّثۡقَلُونَ\n",
        "surah": {
          "number": 68,
