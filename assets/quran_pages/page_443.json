        "hizbQuarter": 177,
        "sajda": false
      },
      {
        "number": 3750,
        "text": "وَإِذَا قِیلَ لَهُمُ ٱتَّقُوا۟ مَا بَیۡنَ أَیۡدِیكُمۡ وَمَا خَلۡفَكُمۡ لَعَلَّكُمۡ تُرۡحَمُونَ\n",
        "surah": {
          "number": 36,
