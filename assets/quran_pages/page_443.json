        "sajda": false
      },
      {
        "number": 3749,
        "text": "إِلَّا رَحۡمَةࣰ مِّنَّا وَمَتَـٰعًا إِلَىٰ حِینࣲ\n",
        "surah": {
          "number": 36,
          "name": "سُورَةُ يسٓ",
          "englishName": "Yaseen",
          "englishNameTranslation": "Yaseen",
