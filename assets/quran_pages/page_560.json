        "hizbQuarter": 224,
        "sajda": false
      },
      {
        "number": 5234,
        "text": "عَسَىٰ رَبُّهُۥۤ إِن طَلَّقَكُنَّ أَن یُبۡدِلَهُۥۤ أَزۡوَ ٰ⁠جًا خَیۡرࣰا مِّنكُنَّ مُسۡلِمَـٰتࣲ مُّؤۡمِنَـٰتࣲ قَـٰنِتَـٰتࣲ تَـٰۤىِٕبَـٰتٍ عَـٰبِدَ ٰ⁠تࣲ سَـٰۤىِٕحَـٰتࣲ ثَیِّبَـٰتࣲ وَأَبۡكَارࣰا\n",
        "surah": {
          "number": 66,
          "name": "سُورَةُ التَّحۡرِيمِ",
          "englishName": "At-Tahrim",
