        "hizbQuarter": 224,
        "sajda": false
      },
      {
        "number": 5233,
        "text": "إِن تَتُوبَاۤ إِلَى ٱللَّهِ فَقَدۡ صَغَتۡ قُلُوبُكُمَاۖ وَإِن تَظَـٰهَرَا عَلَیۡهِ فَإِنَّ ٱللَّهَ هُوَ مَوۡلَىٰهُ وَجِبۡرِیلُ وَصَـٰلِحُ ٱلۡمُؤۡمِنِینَۖ وَٱلۡمَلَـٰۤىِٕكَةُ بَعۡدَ ذَ ٰ⁠لِكَ ظَهِیرٌ\n",
        "surah": {
          "number": 66,
          "name": "سُورَةُ التَّحۡرِيمِ",
          "englishName": "At-Tahrim",
          "englishNameTranslation": "The Prohibition",
