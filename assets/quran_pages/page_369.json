        "hizbQuarter": 147,
        "sajda": false
      },
      {
        "number": 2974,
        "text": "قَالَ نَعَمۡ وَإِنَّكُمۡ إِذࣰا لَّمِنَ ٱلۡمُقَرَّبِینَ\n",
        "surah": {
          "number": 26,
