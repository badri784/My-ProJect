        "hizbQuarter": 147,
        "sajda": false
      },
      {
        "number": 2977,
        "text": "فَأَلۡقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِیَ تَلۡقَفُ مَا یَأۡفِكُونَ\n",
        "surah": {
