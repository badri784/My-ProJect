        "sajda": false
      },
      {
        "number": 2980,
        "text": "رَبِّ مُوسَىٰ وَهَـٰرُونَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
