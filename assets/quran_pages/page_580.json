        "sajda": false
      },
      {
        "number": 5618,
        "text": "إِنَّ هَـٰۤؤُلَاۤءِ یُحِبُّونَ ٱلۡعَاجِلَةَ وَیَذَرُونَ وَرَاۤءَهُمۡ یَوۡمࣰا ثَقِیلࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
