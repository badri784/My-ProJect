        "hizbQuarter": 232,
        "sajda": false
      },
      {
        "number": 5622,
        "text": "یُدۡخِلُ مَن یَشَاۤءُ فِی رَحۡمَتِهِۦۚ وَٱلظَّـٰلِمِینَ أَعَدَّ لَهُمۡ عَذَابًا أَلِیمَۢا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
