        "hizbQuarter": 232,
        "sajda": false
      },
      {
        "number": 5619,
        "text": "نَّحۡنُ خَلَقۡنَـٰهُمۡ وَشَدَدۡنَاۤ أَسۡرَهُمۡۖ وَإِذَا شِئۡنَا بَدَّلۡنَاۤ أَمۡثَـٰلَهُمۡ تَبۡدِیلًا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
