        "hizbQuarter": 129,
        "sajda": false
      },
      {
        "number": 2488,
        "text": "بَلۡ قَالُوۤا۟ أَضۡغَـٰثُ أَحۡلَـٰمِۭ بَلِ ٱفۡتَرَىٰهُ بَلۡ هُوَ شَاعِرࣱ فَلۡیَأۡتِنَا بِـَٔایَةࣲ كَمَاۤ أُرۡسِلَ ٱلۡأَوَّلُونَ\n",
        "surah": {
          "number": 21,
          "name": "سُورَةُ الأَنبِيَاءِ",
          "englishName": "Al-Anbiyaa",
