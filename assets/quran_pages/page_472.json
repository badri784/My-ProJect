        "hizbQuarter": 189,
        "sajda": false
      },
      {
        "number": 4178,
        "text": "فَوَقَىٰهُ ٱللَّهُ سَیِّـَٔاتِ مَا مَكَرُوا۟ۖ وَحَاقَ بِـَٔالِ فِرۡعَوۡنَ سُوۤءُ ٱلۡعَذَابِ\n",
        "surah": {
