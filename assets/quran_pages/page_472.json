        "sajda": false
      },
      {
        "number": 4179,
        "text": "ٱلنَّارُ یُعۡرَضُونَ عَلَیۡهَا غُدُوࣰّا وَعَشِیࣰّاۚ وَیَوۡمَ تَقُومُ ٱلسَّاعَةُ أَدۡخِلُوۤا۟ ءَالَ فِرۡعَوۡنَ أَشَدَّ ٱلۡعَذَابِ\n",
        "surah": {
          "number": 40,
          "name": "سُورَةُ غَافِرٍ",
