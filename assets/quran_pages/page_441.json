        "hizbQuarter": 176,
        "sajda": false
      },
      {
        "number": 3722,
        "text": "وَمَا عَلَیۡنَاۤ إِلَّا ٱلۡبَلَـٰغُ ٱلۡمُبِینُ\n",
        "surah": {
          "number": 36,
          "name": "سُورَةُ يسٓ",
          "englishName": "Yaseen",
