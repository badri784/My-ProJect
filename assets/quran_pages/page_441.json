        "hizbQuarter": 176,
        "sajda": false
      },
      {
        "number": 3723,
        "text": "قَالُوۤا۟ إِنَّا تَطَیَّرۡنَا بِكُمۡۖ لَىِٕن لَّمۡ تَنتَهُوا۟ لَنَرۡجُمَنَّكُمۡ وَلَیَمَسَّنَّكُم مِّنَّا عَذَابٌ أَلِیمࣱ\n",
        "surah": {
          "number": 36,
          "name": "سُورَةُ يسٓ",
