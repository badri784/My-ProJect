        "hizbQuarter": 192,
        "sajda": false
      },
      {
        "number": 4251,
        "text": "وَمَنۡ أَحۡسَنُ قَوۡلࣰا مِّمَّن دَعَاۤ إِلَى ٱللَّهِ وَعَمِلَ صَـٰلِحࣰا وَقَالَ إِنَّنِی مِنَ ٱلۡمُسۡلِمِینَ\n",
        "surah": {
