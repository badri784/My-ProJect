        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5421,
        "text": "قَالَ یَـٰقَوۡمِ إِنِّی لَكُمۡ نَذِیرࣱ مُّبِینٌ\n",
        "surah": {
          "number": 71,
          "name": "سُورَةُ نُوحٍ",
          "englishName": "Nooh",
          "englishNameTranslation": "Noah",
