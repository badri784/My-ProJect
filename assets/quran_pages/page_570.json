        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5418,
        "text": "یَوۡمَ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ سِرَاعࣰا كَأَنَّهُمۡ إِلَىٰ نُصُبࣲ یُوفِضُونَ\n",
        "surah": {
          "number": 70,
          "name": "سُورَةُ المَعَارِجِ",
          "englishName": "Al-Ma'aarij",
          "englishNameTranslation": "The Ascending Stairways",
