        "sajda": false
      },
      {
        "number": 5424,
        "text": "قَالَ رَبِّ إِنِّی دَعَوۡتُ قَوۡمِی لَیۡلࣰا وَنَهَارࣰا\n",
        "surah": {
          "number": 71,
