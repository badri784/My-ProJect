        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5422,
        "text": "أَنِ ٱعۡبُدُوا۟ ٱللَّهَ وَٱتَّقُوهُ وَأَطِیعُونِ\n",
        "surah": {
          "number": 71,
          "name": "سُورَةُ نُوحٍ",
          "englishName": "Nooh",
          "englishNameTranslation": "Noah",
