        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5420,
        "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ إِنَّاۤ أَرۡسَلۡنَا نُوحًا إِلَىٰ قَوۡمِهِۦۤ أَنۡ أَنذِرۡ قَوۡمَكَ مِن قَبۡلِ أَن یَأۡتِیَهُمۡ عَذَابٌ أَلِیمࣱ\n",
        "surah": {
          "number": 71,
          "name": "سُورَةُ نُوحٍ",
          "englishName": "Nooh",
          "englishNameTranslation": "Noah",
