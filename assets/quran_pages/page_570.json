        "sajda": false
      },
      {
        "number": 5417,
        "text": "فَذَرۡهُمۡ یَخُوضُوا۟ وَیَلۡعَبُوا۟ حَتَّىٰ یُلَـٰقُوا۟ یَوۡمَهُمُ ٱلَّذِی یُوعَدُونَ\n",
        "surah": {
          "number": 70,
          "name": "سُورَةُ المَعَارِجِ",
          "englishName": "Al-Ma'aarij",
          "englishNameTranslation": "The Ascending Stairways",
