        "hizbQuarter": 222,
        "sajda": false
      },
      {
        "number": 5201,
        "text": "هُوَ ٱلَّذِی خَلَقَكُمۡ فَمِنكُمۡ كَافِرࣱ وَمِنكُم مُّؤۡمِنࣱۚ وَٱللَّهُ بِمَا تَعۡمَلُونَ بَصِیرٌ\n",
        "surah": {
          "number": 64,
          "name": "سُورَةُ التَّغَابُنِ",
          "englishName": "At-Taghaabun",
          "englishNameTranslation": "Mutual Disillusion",
          "revelationType": "Medinan",
          "numberOfAyahs": 18
        },
        "numberInSurah": 2,
        "juz": 28,
        "manzil": 7,
        "page": 556,
        "ruku": 490,
        "hizbQuarter": 222,
        "sajda": false
      },
      {
        "number": 5202,
        "text": "خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ بِٱلۡحَقِّ وَصَوَّرَكُمۡ فَأَحۡسَنَ صُوَرَكُمۡۖ وَإِلَیۡهِ ٱلۡمَصِیرُ\n",
        "surah": {
          "number": 64,
          "name": "سُورَةُ التَّغَابُنِ",
          "englishName": "At-Taghaabun",
          "englishNameTranslation": "Mutual Disillusion",
          "revelationType": "Medinan",
          "numberOfAyahs": 18
        },
        "numberInSurah": 3,
        "juz": 28,
        "manzil": 7,
        "page": 556,
        "ruku": 490,
        "hizbQuarter": 222,
        "sajda": false
      },
      {
        "number": 5203,
        "text": "یَعۡلَمُ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَیَعۡلَمُ مَا تُسِرُّونَ وَمَا تُعۡلِنُونَۚ وَٱللَّهُ عَلِیمُۢ بِذَاتِ ٱلصُّدُورِ\n",
        "surah": {
          "number": 64,
          "name": "سُورَةُ التَّغَابُنِ",
          "englishName": "At-Taghaabun",
          "englishNameTranslation": "Mutual Disillusion",
          "revelationType": "Medinan",
          "numberOfAyahs": 18
        },
        "numberInSurah": 4,
        "juz": 28,
        "manzil": 7,
        "page": 556,
        "ruku": 490,
        "hizbQuarter": 222,
        "sajda": false
      },
      {
        "number": 5204,
        "text": "أَلَمۡ یَأۡتِكُمۡ نَبَؤُا۟ ٱلَّذِینَ كَفَرُوا۟ مِن قَبۡلُ فَذَاقُوا۟ وَبَالَ أَمۡرِهِمۡ وَلَهُمۡ عَذَابٌ أَلِیمࣱ\n",
        "surah": {
          "number": 64,
          "name": "سُورَةُ التَّغَابُنِ",
          "englishName": "At-Taghaabun",
          "englishNameTranslation": "Mutual Disillusion",
          "revelationType": "Medinan",
          "numberOfAyahs": 18
        },
        "numberInSurah": 5,
        "juz": 28,
        "manzil": 7,
        "page": 556,
        "ruku": 490,
        "hizbQuarter": 222,
        "sajda": false
      },
      {
        "number": 5205,
        "text": "ذَ ٰ⁠لِكَ بِأَنَّهُۥ كَانَت تَّأۡتِیهِمۡ رُسُلُهُم بِٱلۡبَیِّنَـٰتِ فَقَالُوۤا۟ أَبَشَرࣱ یَهۡدُونَنَا فَكَفَرُوا۟ وَتَوَلَّوا۟ۖ وَّٱسۡتَغۡنَى ٱللَّهُۚ وَٱللَّهُ غَنِیٌّ حَمِیدࣱ\n",
        "surah": {
          "number": 64,
          "name": "سُورَةُ التَّغَابُنِ",
          "englishName": "At-Taghaabun",
          "englishNameTranslation": "Mutual Disillusion",
          "revelationType": "Medinan",
          "numberOfAyahs": 18
        },
        "numberInSurah": 6,
        "juz": 28,
        "manzil": 7,
        "page": 556,
        "ruku": 490,
        "hizbQuarter": 222,
        "sajda": false
      },
      {
        "number": 5206,
        "text": "زَعَمَ ٱلَّذِینَ كَفَرُوۤا۟ أَن لَّن یُبۡعَثُوا۟ۚ قُلۡ بَلَىٰ وَرَبِّی لَتُبۡعَثُنَّ ثُمَّ لَتُنَبَّؤُنَّ بِمَا عَمِلۡتُمۡۚ وَذَ ٰ⁠لِكَ عَلَى ٱللَّهِ یَسِیرࣱ\n",
        "surah": {
          "number": 64,
          "name": "سُورَةُ التَّغَابُنِ",
          "englishName": "At-Taghaabun",
          "englishNameTranslation": "Mutual Disillusion",
          "revelationType": "Medinan",
          "numberOfAyahs": 18
        },
        "numberInSurah": 7,
        "juz": 28,
