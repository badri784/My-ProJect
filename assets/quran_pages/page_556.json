    "ayahs": [
      {
        "number": 5200,
        "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ یُسَبِّحُ لِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۖ لَهُ ٱلۡمُلۡكُ وَلَهُ ٱلۡحَمۡدُۖ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ\n",
        "surah": {
          "number": 64,
          "name": "سُورَةُ التَّغَابُنِ",
          "englishName": "At-Taghaabun",
          "englishNameTranslation": "Mutual Disillusion",
          "revelationType": "Medinan",
          "numberOfAyahs": 18
        },
        "numberInSurah": 1,
        "juz": 28,
