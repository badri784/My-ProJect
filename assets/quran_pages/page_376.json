        "hizbQuarter": 150,
        "sajda": false
      },
      {
        "number": 3143,
        "text": "وَمَا یَنۢبَغِی لَهُمۡ وَمَا یَسۡتَطِیعُونَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
