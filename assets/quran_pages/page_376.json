        "hizbQuarter": 150,
        "sajda": false
      },
      {
        "number": 3140,
        "text": "وَمَاۤ أَهۡلَكۡنَا مِن قَرۡیَةٍ إِلَّا لَهَا مُنذِرُونَ\n",
        "surah": {
          "number": 26,
