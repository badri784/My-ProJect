        "hizbQuarter": 150,
        "sajda": false
      },
      {
        "number": 3142,
        "text": "وَمَا تَنَزَّلَتۡ بِهِ ٱلشَّیَـٰطِینُ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
