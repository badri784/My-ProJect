        "hizbQuarter": 150,
        "sajda": false
      },
      {
        "number": 3141,
        "text": "ذِكۡرَىٰ وَمَا كُنَّا ظَـٰلِمِینَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
