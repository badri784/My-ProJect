        "hizbQuarter": 208,
        "sajda": false
      },
      {
        "number": 4689,
        "text": "ذُوقُوا۟ فِتۡنَتَكُمۡ هَـٰذَا ٱلَّذِی كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ\n",
        "surah": {
          "number": 51,
