        "sajda": false
      },
      {
        "number": 2420,
        "text": "قَالُوا۟ لَن نُّؤۡثِرَكَ عَلَىٰ مَا جَاۤءَنَا مِنَ ٱلۡبَیِّنَـٰتِ وَٱلَّذِی فَطَرَنَاۖ فَٱقۡضِ مَاۤ أَنتَ قَاضٍۖ إِنَّمَا تَقۡضِی هَـٰذِهِ ٱلۡحَیَوٰةَ ٱلدُّنۡیَاۤ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
