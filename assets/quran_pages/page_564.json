        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5271,
        "text": "قُلۡ أَرَءَیۡتُمۡ إِنۡ أَصۡبَحَ مَاۤؤُكُمۡ غَوۡرࣰا فَمَن یَأۡتِیكُم بِمَاۤءࣲ مَّعِینِۭ\n",
        "surah": {
