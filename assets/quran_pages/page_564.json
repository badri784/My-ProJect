        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5272,
        "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ نۤۚ وَٱلۡقَلَمِ وَمَا یَسۡطُرُونَ\n",
        "surah": {
          "number": 68,
          "name": "سُورَةُ القَلَمِ",
