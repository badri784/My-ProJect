        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5270,
        "text": "قُلۡ هُوَ ٱلرَّحۡمَـٰنُ ءَامَنَّا بِهِۦ وَعَلَیۡهِ تَوَكَّلۡنَاۖ فَسَتَعۡلَمُونَ مَنۡ هُوَ فِی ضَلَـٰلࣲ مُّبِینࣲ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
          "revelationType": "Meccan",
          "numberOfAyahs": 30
        },
        "numberInSurah": 29,
