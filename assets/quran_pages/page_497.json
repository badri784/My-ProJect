        "hizbQuarter": 199,
        "sajda": false
      },
      {
        "number": 4441,
        "text": "وَنَعۡمَةࣲ كَانُوا۟ فِیهَا فَـٰكِهِینَ\n",
        "surah": {
          "number": 44,
          "name": "سُورَةُ الدُّخَانِ",
