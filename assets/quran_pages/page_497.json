        "page": 497,
        "ruku": 431,
        "hizbQuarter": 199,
        "sajda": false
      },
      {
        "number": 4444,
        "text": "وَلَقَدۡ نَجَّیۡنَا بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ مِنَ ٱلۡعَذَابِ ٱلۡمُهِینِ\n",
        "surah": {
          "number": 44,
          "name": "سُورَةُ الدُّخَانِ",
          "englishName": "Ad-Dukhaan",
          "englishNameTranslation": "The Smoke",
          "revelationType": "Meccan",
          "numberOfAyahs": 59
        },
        "numberInSurah": 30,
        "juz": 25,
