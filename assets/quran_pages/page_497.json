        "hizbQuarter": 199,
        "sajda": false
      },
      {
        "number": 4440,
        "text": "وَزُرُوعࣲ وَمَقَامࣲ كَرِیمࣲ\n",
        "surah": {
          "number": 44,
          "name": "سُورَةُ الدُّخَانِ",
          "englishName": "Ad-Dukhaan",
          "englishNameTranslation": "The Smoke",
