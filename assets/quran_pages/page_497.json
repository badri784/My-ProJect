        "hizbQuarter": 199,
        "sajda": false
      },
      {
        "number": 4447,
        "text": "وَءَاتَیۡنَـٰهُم مِّنَ ٱلۡـَٔایَـٰتِ مَا فِیهِ بَلَـٰۤؤࣱا۟ مُّبِینٌ\n",
        "surah": {
