        "hizbQuarter": 199,
        "sajda": false
      },
      {
        "number": 4442,
        "text": "كَذَ ٰ⁠لِكَۖ وَأَوۡرَثۡنَـٰهَا قَوۡمًا ءَاخَرِینَ\n",
        "surah": {
          "number": 44,
          "name": "سُورَةُ الدُّخَانِ",
          "englishName": "Ad-Dukhaan",
