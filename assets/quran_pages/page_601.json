        "page": 601,
        "ruku": 545,
        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6180,
        "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ وَیۡلࣱ لِّكُلِّ هُمَزَةࣲ لُّمَزَةٍ\n",
        "surah": {
          "number": 104,
          "name": "سُورَةُ الهُمَزَةِ",
          "englishName": "Al-Humaza",
          "englishNameTranslation": "The Traducer",
