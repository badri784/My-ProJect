        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6178,
        "text": "إِنَّ ٱلۡإِنسَـٰنَ لَفِی خُسۡرٍ\n",
        "surah": {
          "number": 103,
          "name": "سُورَةُ العَصۡرِ",
