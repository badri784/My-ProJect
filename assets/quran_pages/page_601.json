        "sajda": false
      },
      {
        "number": 6185,
        "text": "نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ\n",
        "surah": {
          "number": 104,
          "name": "سُورَةُ الهُمَزَةِ",
