        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6183,
        "text": "كَلَّاۖ لَیُنۢبَذَنَّ فِی ٱلۡحُطَمَةِ\n",
        "surah": {
          "number": 104,
