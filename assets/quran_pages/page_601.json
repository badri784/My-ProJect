        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6186,
        "text": "ٱلَّتِی تَطَّلِعُ عَلَى ٱلۡأَفۡـِٔدَةِ\n",
        "surah": {
          "number": 104,
