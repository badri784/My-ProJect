        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6182,
        "text": "یَحۡسَبُ أَنَّ مَالَهُۥۤ أَخۡلَدَهُۥ\n",
        "surah": {
          "number": 104,
          "name": "سُورَةُ الهُمَزَةِ",
          "englishName": "Al-Humaza",
