        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6184,
        "text": "وَمَاۤ أَدۡرَىٰكَ مَا ٱلۡحُطَمَةُ\n",
        "surah": {
          "number": 104,
          "name": "سُورَةُ الهُمَزَةِ",
