        "page": 601,
        "ruku": 546,
        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6181,
        "text": "ٱلَّذِی جَمَعَ مَالࣰا وَعَدَّدَهُۥ\n",
        "surah": {
          "number": 104,
          "name": "سُورَةُ الهُمَزَةِ",
          "englishName": "Al-Humaza",
          "englishNameTranslation": "The Traducer",
