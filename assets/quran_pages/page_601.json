        "hizbQuarter": 240,
        "sajda": false
      },
      {
        "number": 6179,
        "text": "إِلَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ وَتَوَاصَوۡا۟ بِٱلۡحَقِّ وَتَوَاصَوۡا۟ بِٱلصَّبۡرِ\n",
        "surah": {
          "number": 103,
          "name": "سُورَةُ العَصۡرِ",
          "englishName": "Al-Asr",
          "englishNameTranslation": "The Declining Day, Epoch",
          "revelationType": "Meccan",
          "numberOfAyahs": 3
        },
        "numberInSurah": 3,
        "juz": 30,
