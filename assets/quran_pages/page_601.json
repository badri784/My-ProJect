      {
        "number": 6177,
        "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَـٰنِ ٱلرَّحِیمِ وَٱلۡعَصۡرِ\n",
        "surah": {
          "number": 103,
          "name": "سُورَةُ العَصۡرِ",
