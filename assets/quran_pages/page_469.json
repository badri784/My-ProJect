        "hizbQuarter": 187,
        "sajda": false
      },
      {
        "number": 4153,
        "text": "وَٱللَّهُ یَقۡضِی بِٱلۡحَقِّۖ وَٱلَّذِینَ یَدۡعُونَ مِن دُونِهِۦ لَا یَقۡضُونَ بِشَیۡءٍۗ إِنَّ ٱللَّهَ هُوَ ٱلسَّمِیعُ ٱلۡبَصِیرُ\n",
        "surah": {
          "number": 40,
          "name": "سُورَةُ غَافِرٍ",
          "englishName": "Ghafir",
          "englishNameTranslation": "The Forgiver",
