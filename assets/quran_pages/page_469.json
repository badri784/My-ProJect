        "sajda": false
      },
      {
        "number": 4152,
        "text": "یَعۡلَمُ خَاۤىِٕنَةَ ٱلۡأَعۡیُنِ وَمَا تُخۡفِی ٱلصُّدُورُ\n",
        "surah": {
