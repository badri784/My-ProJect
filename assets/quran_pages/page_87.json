        "hizbQuarter": 34,
        "sajda": false
      },
      {
        "number": 548,
        "text": "فَمِنۡهُم مَّنۡ ءَامَنَ بِهِۦ وَمِنۡهُم مَّن صَدَّ عَنۡهُۚ وَكَفَىٰ بِجَهَنَّمَ سَعِیرًا\n",
        "surah": {
