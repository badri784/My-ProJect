        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5574,
        "text": "إِلَىٰ رَبِّهَا نَاظِرَةࣱ\n",
        "surah": {
          "number": 75,
          "name": "سُورَةُ القِيَامَةِ",
          "englishName": "Al-Qiyaama",
