        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5575,
        "text": "وَوُجُوهࣱ یَوۡمَىِٕذِۭ بَاسِرَةࣱ\n",
        "surah": {
          "number": 75,
          "name": "سُورَةُ القِيَامَةِ",
          "englishName": "Al-Qiyaama",
          "englishNameTranslation": "The Resurrection",
