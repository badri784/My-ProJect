        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5573,
        "text": "وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاضِرَةٌ\n",
        "surah": {
          "number": 75,
          "name": "سُورَةُ القِيَامَةِ",
