        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5577,
        "text": "كَلَّاۤ إِذَا بَلَغَتِ ٱلتَّرَاقِیَ\n",
        "surah": {
          "number": 75,
          "name": "سُورَةُ القِيَامَةِ",
