        "page": 578,
        "ruku": 512,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5576,
        "text": "تَظُنُّ أَن یُفۡعَلَ بِهَا فَاقِرَةࣱ\n",
        "surah": {
          "number": 75,
          "name": "سُورَةُ القِيَامَةِ",
          "englishName": "Al-Qiyaama",
