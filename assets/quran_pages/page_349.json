        "hizbQuarter": 139,
        "sajda": false
      },
      {
        "number": 2780,
        "text": "رَبَّنَاۤ أَخۡرِجۡنَا مِنۡهَا فَإِنۡ عُدۡنَا فَإِنَّا ظَـٰلِمُونَ\n",
        "surah": {
          "number": 23,
