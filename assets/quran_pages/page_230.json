        "sajda": false
      },
      {
        "number": 1548,
        "text": "إِنَّ إِبۡرَ ٰ⁠هِیمَ لَحَلِیمٌ أَوَّ ٰ⁠هࣱ مُّنِیبࣱ\n",
        "surah": {
