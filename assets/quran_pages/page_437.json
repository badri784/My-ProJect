        "hizbQuarter": 175,
        "sajda": false
      },
      {
        "number": 3684,
        "text": "إِنَّاۤ أَرۡسَلۡنَـٰكَ بِٱلۡحَقِّ بَشِیرࣰا وَنَذِیرࣰاۚ وَإِن مِّنۡ أُمَّةٍ إِلَّا خَلَا فِیهَا نَذِیرࣱ\n",
        "surah": {
          "number": 35,
          "name": "سُورَةُ فَاطِرٍ",
