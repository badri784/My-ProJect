        "sajda": false
      },
      {
        "number": 3686,
        "text": "ثُمَّ أَخَذۡتُ ٱلَّذِینَ كَفَرُوا۟ۖ فَكَیۡفَ كَانَ نَكِیرِ\n",
        "surah": {
          "number": 35,
