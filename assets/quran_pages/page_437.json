        "hizbQuarter": 175,
        "sajda": false
      },
      {
        "number": 3687,
        "text": "أَلَمۡ تَرَ أَنَّ ٱللَّهَ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَأَخۡرَجۡنَا بِهِۦ ثَمَرَ ٰ⁠تࣲ مُّخۡتَلِفًا أَلۡوَ ٰ⁠نُهَاۚ وَمِنَ ٱلۡجِبَالِ جُدَدُۢ بِیضࣱ وَحُمۡرࣱ مُّخۡتَلِفٌ أَلۡوَ ٰ⁠نُهَا وَغَرَابِیبُ سُودࣱ\n",
        "surah": {
          "number": 35,
          "name": "سُورَةُ فَاطِرٍ",
          "englishName": "Faatir",
          "englishNameTranslation": "The Originator",
