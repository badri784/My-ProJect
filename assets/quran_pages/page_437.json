        "hizbQuarter": 175,
        "sajda": false
      },
      {
        "number": 3683,
        "text": "إِنۡ أَنتَ إِلَّا نَذِیرٌ\n",
        "surah": {
          "number": 35,
          "name": "سُورَةُ فَاطِرٍ",
