        "sajda": false
      },
      {
        "number": 5919,
        "text": "إِنَّ ٱلَّذِینَ فَتَنُوا۟ ٱلۡمُؤۡمِنِینَ وَٱلۡمُؤۡمِنَـٰتِ ثُمَّ لَمۡ یَتُوبُوا۟ فَلَهُمۡ عَذَابُ جَهَنَّمَ وَلَهُمۡ عَذَابُ ٱلۡحَرِیقِ\n",
        "surah": {
          "number": 85,
          "name": "سُورَةُ البُرُوجِ",
          "englishName": "Al-Burooj",
