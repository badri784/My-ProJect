        "sajda": false
      },
      {
        "number": 5920,
        "text": "إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمۡ جَنَّـٰتࣱ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۚ ذَ ٰ⁠لِكَ ٱلۡفَوۡزُ ٱلۡكَبِیرُ\n",
        "surah": {
          "number": 85,
