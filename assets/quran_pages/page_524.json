        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4756,
        "text": "وَٱلَّذِینَ ءَامَنُوا۟ وَٱتَّبَعَتۡهُمۡ ذُرِّیَّتُهُم بِإِیمَـٰنٍ أَلۡحَقۡنَا بِهِمۡ ذُرِّیَّتَهُمۡ وَمَاۤ أَلَتۡنَـٰهُم مِّنۡ عَمَلِهِم مِّن شَیۡءࣲۚ كُلُّ ٱمۡرِىِٕۭ بِمَا كَسَبَ رَهِینࣱ\n",
        "surah": {
          "number": 52,
          "name": "سُورَةُ الطُّورِ",
          "englishName": "At-Tur",
          "englishNameTranslation": "The Mount",
          "revelationType": "Meccan",
          "numberOfAyahs": 49
        },
        "numberInSurah": 21,
