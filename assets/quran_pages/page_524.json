        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4754,
        "text": "كُلُوا۟ وَٱشۡرَبُوا۟ هَنِیۤـَٔۢا بِمَا كُنتُمۡ تَعۡمَلُونَ\n",
        "surah": {
