        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4757,
        "text": "وَأَمۡدَدۡنَـٰهُم بِفَـٰكِهَةࣲ وَلَحۡمࣲ مِّمَّا یَشۡتَهُونَ\n",
        "surah": {
          "number": 52,
          "name": "سُورَةُ الطُّورِ",
          "englishName": "At-Tur",
          "englishNameTranslation": "The Mount",
