        "sajda": false
      },
      {
        "number": 4755,
        "text": "مُتَّكِـِٔینَ عَلَىٰ سُرُرࣲ مَّصۡفُوفَةࣲۖ وَزَوَّجۡنَـٰهُم بِحُورٍ عِینࣲ\n",
        "surah": {
          "number": 52,
          "name": "سُورَةُ الطُّورِ",
          "englishName": "At-Tur",
          "englishNameTranslation": "The Mount",
