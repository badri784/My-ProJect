        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4758,
        "text": "یَتَنَـٰزَعُونَ فِیهَا كَأۡسࣰا لَّا لَغۡوࣱ فِیهَا وَلَا تَأۡثِیمࣱ\n",
        "surah": {
          "number": 52,
