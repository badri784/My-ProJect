        "hizbQuarter": 179,
        "sajda": false
      },
      {
        "number": 3819,
        "text": "فَحَقَّ عَلَیۡنَا قَوۡلُ رَبِّنَاۤۖ إِنَّا لَذَاۤىِٕقُونَ\n",
        "surah": {
          "number": 37,
