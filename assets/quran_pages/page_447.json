        "hizbQuarter": 179,
        "sajda": false
      },
      {
        "number": 3816,
        "text": "قَالُوۤا۟ إِنَّكُمۡ كُنتُمۡ تَأۡتُونَنَا عَنِ ٱلۡیَمِینِ\n",
        "surah": {
          "number": 37,
