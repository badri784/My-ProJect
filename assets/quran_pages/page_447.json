        "hizbQuarter": 179,
        "sajda": false
      },
      {
        "number": 3815,
        "text": "وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَسَاۤءَلُونَ\n",
        "surah": {
          "number": 37,
