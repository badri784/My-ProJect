        "hizbQuarter": 174,
        "sajda": false
      },
      {
        "number": 3669,
        "text": "وَٱللَّهُ ٱلَّذِیۤ أَرۡسَلَ ٱلرِّیَـٰحَ فَتُثِیرُ سَحَابࣰا فَسُقۡنَـٰهُ إِلَىٰ بَلَدࣲ مَّیِّتࣲ فَأَحۡیَیۡنَا بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۚ كَذَ ٰ⁠لِكَ ٱلنُّشُورُ\n",
        "surah": {
          "number": 35,
