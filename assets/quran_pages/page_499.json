        "hizbQuarter": 199,
        "sajda": false
      },
      {
        "number": 4484,
        "text": "هَـٰذَا هُدࣰىۖ وَٱلَّذِینَ كَفَرُوا۟ بِـَٔایَـٰتِ رَبِّهِمۡ لَهُمۡ عَذَابࣱ مِّن رِّجۡزٍ أَلِیمٌ\n",
        "surah": {
          "number": 45,
