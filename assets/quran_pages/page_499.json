        "hizbQuarter": 199,
        "sajda": false
      },
      {
        "number": 4480,
        "text": "وَیۡلࣱ لِّكُلِّ أَفَّاكٍ أَثِیمࣲ\n",
        "surah": {
          "number": 45,
          "name": "سُورَةُ الجَاثِيَةِ",
          "englishName": "Al-Jaathiya",
          "englishNameTranslation": "Crouching",
