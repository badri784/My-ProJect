        "sajda": false
      },
      {
        "number": 1653,
        "text": "وَلَأَجۡرُ ٱلۡـَٔاخِرَةِ خَیۡرࣱ لِّلَّذِینَ ءَامَنُوا۟ وَكَانُوا۟ یَتَّقُونَ\n",
        "surah": {
          "number": 12,
