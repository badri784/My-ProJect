        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5264,
        "text": "قُلۡ هُوَ ٱلَّذِیۤ أَنشَأَكُمۡ وَجَعَلَ لَكُمُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ وَٱلۡأَفۡـِٔدَةَۚ قَلِیلࣰا مَّا تَشۡكُرُونَ\n",
        "surah": {
          "number": 67,
