        "sajda": false
      },
      {
        "number": 5263,
        "text": "أَفَمَن یَمۡشِی مُكِبًّا عَلَىٰ وَجۡهِهِۦۤ أَهۡدَىٰۤ أَمَّن یَمۡشِی سَوِیًّا عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
