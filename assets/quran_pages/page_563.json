        "sajda": false
      },
      {
        "number": 5262,
        "text": "أَمَّنۡ هَـٰذَا ٱلَّذِی یَرۡزُقُكُمۡ إِنۡ أَمۡسَكَ رِزۡقَهُۥۚ بَل لَّجُّوا۟ فِی عُتُوࣲّ وَنُفُورٍ\n",
        "surah": {
          "number": 67,
