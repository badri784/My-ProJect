        "page": 563,
        "ruku": 497,
        "hizbQuarter": 225,
        "sajda": false
      },
      {
        "number": 5259,
        "text": "وَلَقَدۡ كَذَّبَ ٱلَّذِینَ مِن قَبۡلِهِمۡ فَكَیۡفَ كَانَ نَكِیرِ\n",
        "surah": {
          "number": 67,
          "name": "سُورَةُ المُلۡكِ",
          "englishName": "Al-Mulk",
          "englishNameTranslation": "The Sovereignty",
