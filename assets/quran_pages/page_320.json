        "page": 320,
        "ruku": 276,
        "hizbQuarter": 128,
        "sajda": false
      },
      {
        "number": 2467,
        "text": "وَأَنَّكَ لَا تَظۡمَؤُا۟ فِیهَا وَلَا تَضۡحَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
