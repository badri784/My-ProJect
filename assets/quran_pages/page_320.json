        "page": 320,
        "ruku": 276,
        "hizbQuarter": 128,
        "sajda": false
      },
      {
        "number": 2465,
        "text": "فَقُلۡنَا یَـٰۤـَٔادَمُ إِنَّ هَـٰذَا عَدُوࣱّ لَّكَ وَلِزَوۡجِكَ فَلَا یُخۡرِجَنَّكُمَا مِنَ ٱلۡجَنَّةِ فَتَشۡقَىٰۤ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
