        "sajda": false
      },
      {
        "number": 3049,
        "text": "قَالَ رَبِّ إِنَّ قَوۡمِی كَذَّبُونِ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
