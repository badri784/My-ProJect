        "hizbQuarter": 149,
        "sajda": false
      },
      {
        "number": 3050,
        "text": "فَٱفۡتَحۡ بَیۡنِی وَبَیۡنَهُمۡ فَتۡحࣰا وَنَجِّنِی وَمَن مَّعِیَ مِنَ ٱلۡمُؤۡمِنِینَ\n",
        "surah": {
          "number": 26,
