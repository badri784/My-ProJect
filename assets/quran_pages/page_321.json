        "sajda": false
      },
      {
        "number": 2477,
        "text": "وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ لَكَانَ لِزَامࣰا وَأَجَلࣱ مُّسَمࣰّى\n",
        "surah": {
