        "page": 313,
        "ruku": 271,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2375,
        "text": "وَٱحۡلُلۡ عُقۡدَةࣰ مِّن لِّسَانِی\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
