        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2372,
        "text": "ٱذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 24,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2373,
        "text": "قَالَ رَبِّ ٱشۡرَحۡ لِی صَدۡرِی\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 25,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 271,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2374,
        "text": "وَیَسِّرۡ لِیۤ أَمۡرِی\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
