        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2377,
        "text": "وَٱجۡعَل لِّی وَزِیرࣰا مِّنۡ أَهۡلِی\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
