        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2376,
        "text": "یَفۡقَهُوا۟ قَوۡلِی\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
