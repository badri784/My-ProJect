        },
        "numberInSurah": 13,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2362,
        "text": "إِنَّنِیۤ أَنَا ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدۡنِی وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِیۤ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 14,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2363,
        "text": "إِنَّ ٱلسَّاعَةَ ءَاتِیَةٌ أَكَادُ أُخۡفِیهَا لِتُجۡزَىٰ كُلُّ نَفۡسِۭ بِمَا تَسۡعَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 15,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2364,
        "text": "فَلَا یَصُدَّنَّكَ عَنۡهَا مَن لَّا یُؤۡمِنُ بِهَا وَٱتَّبَعَ هَوَىٰهُ فَتَرۡدَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 16,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2365,
        "text": "وَمَا تِلۡكَ بِیَمِینِكَ یَـٰمُوسَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 17,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2366,
        "text": "قَالَ هِیَ عَصَایَ أَتَوَكَّؤُا۟ عَلَیۡهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِی وَلِیَ فِیهَا مَـَٔارِبُ أُخۡرَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 18,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2367,
        "text": "قَالَ أَلۡقِهَا یَـٰمُوسَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 19,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2368,
        "text": "فَأَلۡقَىٰهَا فَإِذَا هِیَ حَیَّةࣱ تَسۡعَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 20,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2369,
        "text": "قَالَ خُذۡهَا وَلَا تَخَفۡۖ سَنُعِیدُهَا سِیرَتَهَا ٱلۡأُولَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
