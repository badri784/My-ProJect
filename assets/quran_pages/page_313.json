        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2370,
        "text": "وَٱضۡمُمۡ یَدَكَ إِلَىٰ جَنَاحِكَ تَخۡرُجۡ بَیۡضَاۤءَ مِنۡ غَیۡرِ سُوۤءٍ ءَایَةً أُخۡرَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 22,
        "juz": 16,
        "manzil": 4,
        "page": 313,
        "ruku": 270,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2371,
        "text": "لِنُرِیَكَ مِنۡ ءَایَـٰتِنَا ٱلۡكُبۡرَى\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 23,
        "juz": 16,
