        "sajda": false
      },
      {
        "number": 4307,
        "text": "وَیَعۡلَمَ ٱلَّذِینَ یُجَـٰدِلُونَ فِیۤ ءَایَـٰتِنَا مَا لَهُم مِّن مَّحِیصࣲ\n",
        "surah": {
          "number": 42,
          "name": "سُورَةُ الشُّورَىٰ",
