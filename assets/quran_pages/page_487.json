        "sajda": false
      },
      {
        "number": 4308,
        "text": "فَمَاۤ أُوتِیتُم مِّن شَیۡءࣲ فَمَتَـٰعُ ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۚ وَمَا عِندَ ٱللَّهِ خَیۡرࣱ وَأَبۡقَىٰ لِلَّذِینَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمۡ یَتَوَكَّلُونَ\n",
        "surah": {
          "number": 42,
          "name": "سُورَةُ الشُّورَىٰ",
          "englishName": "Ash-Shura",
