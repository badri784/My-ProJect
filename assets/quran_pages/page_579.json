        "page": 579,
        "ruku": 514,
        "hizbQuarter": 232,
        "sajda": false
      },
      {
        "number": 5613,
        "text": "إِنَّ هَـٰذَا كَانَ لَكُمۡ جَزَاۤءࣰ وَكَانَ سَعۡیُكُم مَّشۡكُورًا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 22,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 232,
        "sajda": false
      },
      {
        "number": 5614,
        "text": "إِنَّا نَحۡنُ نَزَّلۡنَا عَلَیۡكَ ٱلۡقُرۡءَانَ تَنزِیلࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 23,
