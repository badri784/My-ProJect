  "data": {
    "number": 579,
    "ayahs": [
      {
        "number": 5597,
        "text": "عَیۡنࣰا یَشۡرَبُ بِهَا عِبَادُ ٱللَّهِ یُفَجِّرُونَهَا تَفۡجِیرࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 6,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5598,
        "text": "یُوفُونَ بِٱلنَّذۡرِ وَیَخَافُونَ یَوۡمࣰا كَانَ شَرُّهُۥ مُسۡتَطِیرࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 7,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5599,
        "text": "وَیُطۡعِمُونَ ٱلطَّعَامَ عَلَىٰ حُبِّهِۦ مِسۡكِینࣰا وَیَتِیمࣰا وَأَسِیرًا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 8,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5600,
        "text": "إِنَّمَا نُطۡعِمُكُمۡ لِوَجۡهِ ٱللَّهِ لَا نُرِیدُ مِنكُمۡ جَزَاۤءࣰ وَلَا شُكُورًا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 9,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5601,
        "text": "إِنَّا نَخَافُ مِن رَّبِّنَا یَوۡمًا عَبُوسࣰا قَمۡطَرِیرࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 10,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5602,
        "text": "فَوَقَىٰهُمُ ٱللَّهُ شَرَّ ذَ ٰ⁠لِكَ ٱلۡیَوۡمِ وَلَقَّىٰهُمۡ نَضۡرَةࣰ وَسُرُورࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 11,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5603,
        "text": "وَجَزَىٰهُم بِمَا صَبَرُوا۟ جَنَّةࣰ وَحَرِیرࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 12,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5604,
        "text": "مُّتَّكِـِٔینَ فِیهَا عَلَى ٱلۡأَرَاۤىِٕكِۖ لَا یَرَوۡنَ فِیهَا شَمۡسࣰا وَلَا زَمۡهَرِیرࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 13,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5605,
        "text": "وَدَانِیَةً عَلَیۡهِمۡ ظِلَـٰلُهَا وَذُلِّلَتۡ قُطُوفُهَا تَذۡلِیلࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 14,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5606,
        "text": "وَیُطَافُ عَلَیۡهِم بِـَٔانِیَةࣲ مِّن فِضَّةࣲ وَأَكۡوَابࣲ كَانَتۡ قَوَارِیرَا۠\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 15,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5607,
        "text": "قَوَارِیرَا۟ مِن فِضَّةࣲ قَدَّرُوهَا تَقۡدِیرࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 16,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5608,
        "text": "وَیُسۡقَوۡنَ فِیهَا كَأۡسࣰا كَانَ مِزَاجُهَا زَنجَبِیلًا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 17,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5609,
        "text": "عَیۡنࣰا فِیهَا تُسَمَّىٰ سَلۡسَبِیلࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 18,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 231,
        "sajda": false
      },
      {
        "number": 5610,
        "text": "۞ وَیَطُوفُ عَلَیۡهِمۡ وِلۡدَ ٰ⁠نࣱ مُّخَلَّدُونَ إِذَا رَأَیۡتَهُمۡ حَسِبۡتَهُمۡ لُؤۡلُؤࣰا مَّنثُورࣰا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 19,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 232,
        "sajda": false
      },
      {
        "number": 5611,
        "text": "وَإِذَا رَأَیۡتَ ثَمَّ رَأَیۡتَ نَعِیمࣰا وَمُلۡكࣰا كَبِیرًا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 20,
        "juz": 29,
        "manzil": 7,
        "page": 579,
        "ruku": 514,
        "hizbQuarter": 232,
        "sajda": false
      },
      {
        "number": 5612,
        "text": "عَـٰلِیَهُمۡ ثِیَابُ سُندُسٍ خُضۡرࣱ وَإِسۡتَبۡرَقࣱۖ وَحُلُّوۤا۟ أَسَاوِرَ مِن فِضَّةࣲ وَسَقَىٰهُمۡ رَبُّهُمۡ شَرَابࣰا طَهُورًا\n",
        "surah": {
          "number": 76,
          "name": "سُورَةُ الإِنسَانِ",
          "englishName": "Al-Insaan",
          "englishNameTranslation": "Man",
          "revelationType": "Medinan",
          "numberOfAyahs": 31
        },
        "numberInSurah": 21,
        "juz": 29,
