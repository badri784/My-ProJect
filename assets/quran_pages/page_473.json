        "hizbQuarter": 189,
        "sajda": false
      },
      {
        "number": 4185,
        "text": "یَوۡمَ لَا یَنفَعُ ٱلظَّـٰلِمِینَ مَعۡذِرَتُهُمۡۖ وَلَهُمُ ٱللَّعۡنَةُ وَلَهُمۡ سُوۤءُ ٱلدَّارِ\n",
        "surah": {
