        "hizbQuarter": 189,
        "sajda": false
      },
      {
        "number": 4186,
        "text": "وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡهُدَىٰ وَأَوۡرَثۡنَا بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ٱلۡكِتَـٰبَ\n",
        "surah": {
          "number": 40,
          "name": "سُورَةُ غَافِرٍ",
