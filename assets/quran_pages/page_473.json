        "hizbQuarter": 189,
        "sajda": false
      },
      {
        "number": 4189,
        "text": "إِنَّ ٱلَّذِینَ یُجَـٰدِلُونَ فِیۤ ءَایَـٰتِ ٱللَّهِ بِغَیۡرِ سُلۡطَـٰنٍ أَتَىٰهُمۡ إِن فِی صُدُورِهِمۡ إِلَّا كِبۡرࣱ مَّا هُم بِبَـٰلِغِیهِۚ فَٱسۡتَعِذۡ بِٱللَّهِۖ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡبَصِیرُ\n",
        "surah": {
          "number": 40,
          "name": "سُورَةُ غَافِرٍ",
          "englishName": "Ghafir",
          "englishNameTranslation": "The Forgiver",
