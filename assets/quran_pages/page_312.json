        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2351,
        "text": "إِلَّا تَذۡكِرَةࣰ لِّمَن یَخۡشَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
