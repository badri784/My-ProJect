        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2353,
        "text": "ٱلرَّحۡمَـٰنُ عَلَى ٱلۡعَرۡشِ ٱسۡتَوَىٰ\n",
        "surah": {
          "number": 20,
