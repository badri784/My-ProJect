        "sajda": false
      },
      {
        "number": 2352,
        "text": "تَنزِیلࣰا مِّمَّنۡ خَلَقَ ٱلۡأَرۡضَ وَٱلسَّمَـٰوَ ٰ⁠تِ ٱلۡعُلَى\n",
        "surah": {
