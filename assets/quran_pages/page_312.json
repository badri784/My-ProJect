        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2357,
        "text": "وَهَلۡ أَتَىٰكَ حَدِیثُ مُوسَىٰۤ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
