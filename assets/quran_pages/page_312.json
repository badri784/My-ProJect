        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2354,
        "text": "لَهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا وَمَا تَحۡتَ ٱلثَّرَىٰ\n",
        "surah": {
