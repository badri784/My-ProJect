        "hizbQuarter": 126,
        "sajda": false
      },
      {
        "number": 2411,
        "text": "قَالُوۤا۟ إِنۡ هَـٰذَ ٰ⁠نِ لَسَـٰحِرَ ٰ⁠نِ یُرِیدَانِ أَن یُخۡرِجَاكُم مِّنۡ أَرۡضِكُم بِسِحۡرِهِمَا وَیَذۡهَبَا بِطَرِیقَتِكُمُ ٱلۡمُثۡلَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
