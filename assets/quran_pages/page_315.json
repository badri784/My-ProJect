        "sajda": false
      },
      {
        "number": 2401,
        "text": "ٱلَّذِی جَعَلَ لَكُمُ ٱلۡأَرۡضَ مَهۡدࣰا وَسَلَكَ لَكُمۡ فِیهَا سُبُلࣰا وَأَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَأَخۡرَجۡنَا بِهِۦۤ أَزۡوَ ٰ⁠جࣰا مِّن نَّبَاتࣲ شَتَّىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 53,
        "juz": 16,
        "manzil": 4,
        "page": 315,
        "ruku": 271,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2402,
        "text": "كُلُوا۟ وَٱرۡعَوۡا۟ أَنۡعَـٰمَكُمۡۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّأُو۟لِی ٱلنُّهَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 54,
        "juz": 16,
        "manzil": 4,
        "page": 315,
        "ruku": 271,
        "hizbQuarter": 125,
        "sajda": false
      },
      {
        "number": 2403,
        "text": "۞ مِنۡهَا خَلَقۡنَـٰكُمۡ وَفِیهَا نُعِیدُكُمۡ وَمِنۡهَا نُخۡرِجُكُمۡ تَارَةً أُخۡرَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 55,
        "juz": 16,
        "manzil": 4,
        "page": 315,
        "ruku": 272,
        "hizbQuarter": 126,
        "sajda": false
      },
      {
        "number": 2404,
        "text": "وَلَقَدۡ أَرَیۡنَـٰهُ ءَایَـٰتِنَا كُلَّهَا فَكَذَّبَ وَأَبَىٰ\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
          "revelationType": "Meccan",
          "numberOfAyahs": 135
        },
        "numberInSurah": 56,
        "juz": 16,
