      {
        "number": 2400,
        "text": "قَالَ عِلۡمُهَا عِندَ رَبِّی فِی كِتَـٰبࣲۖ لَّا یَضِلُّ رَبِّی وَلَا یَنسَى\n",
        "surah": {
          "number": 20,
          "name": "سُورَةُ طه",
          "englishName": "Taa-Haa",
          "englishNameTranslation": "Taa-Haa",
