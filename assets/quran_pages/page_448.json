      {
        "number": 3840,
        "text": "یَقُولُ أَءِنَّكَ لَمِنَ ٱلۡمُصَدِّقِینَ\n",
        "surah": {
          "number": 37,
          "name": "سُورَةُ الصَّافَّاتِ",
          "englishName": "As-Saaffaat",
