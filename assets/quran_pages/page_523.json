        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4728,
        "text": "أَتَوَاصَوۡا۟ بِهِۦۚ بَلۡ هُمۡ قَوۡمࣱ طَاغُونَ\n",
        "surah": {
          "number": 51,
          "name": "سُورَةُ الذَّارِيَاتِ",
          "englishName": "Adh-Dhaariyat",
          "englishNameTranslation": "The Winnowing Winds",
