        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4730,
        "text": "وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِینَ\n",
        "surah": {
          "number": 51,
          "name": "سُورَةُ الذَّارِيَاتِ",
          "englishName": "Adh-Dhaariyat",
          "englishNameTranslation": "The Winnowing Winds",
          "revelationType": "Meccan",
          "numberOfAyahs": 60
        },
        "numberInSurah": 55,
        "juz": 27,
        "manzil": 7,
        "page": 523,
        "ruku": 457,
        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4731,
        "text": "وَمَا خَلَقۡتُ ٱلۡجِنَّ وَٱلۡإِنسَ إِلَّا لِیَعۡبُدُونِ\n",
        "surah": {
          "number": 51,
          "name": "سُورَةُ الذَّارِيَاتِ",
          "englishName": "Adh-Dhaariyat",
          "englishNameTranslation": "The Winnowing Winds",
          "revelationType": "Meccan",
          "numberOfAyahs": 60
        },
        "numberInSurah": 56,
        "juz": 27,
        "manzil": 7,
        "page": 523,
        "ruku": 457,
        "hizbQuarter": 209,
        "sajda": false
      },
      {
        "number": 4732,
        "text": "مَاۤ أُرِیدُ مِنۡهُم مِّن رِّزۡقࣲ وَمَاۤ أُرِیدُ أَن یُطۡعِمُونِ\n",
        "surah": {
          "number": 51,
          "name": "سُورَةُ الذَّارِيَاتِ",
          "englishName": "Adh-Dhaariyat",
          "englishNameTranslation": "The Winnowing Winds",
          "revelationType": "Meccan",
          "numberOfAyahs": 60
