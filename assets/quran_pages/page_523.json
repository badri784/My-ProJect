        "sajda": false
      },
      {
        "number": 4735,
        "text": "فَوَیۡلࣱ لِّلَّذِینَ كَفَرُوا۟ مِن یَوۡمِهِمُ ٱلَّذِی یُوعَدُونَ\n",
        "surah": {
          "number": 51,
