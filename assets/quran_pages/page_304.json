        "sajda": false
      },
      {
        "number": 2241,
        "text": "ٱلَّذِینَ كَانَتۡ أَعۡیُنُهُمۡ فِی غِطَاۤءٍ عَن ذِكۡرِی وَكَانُوا۟ لَا یَسۡتَطِیعُونَ سَمۡعًا\n",
        "surah": {
          "number": 18,
