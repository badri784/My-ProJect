        "hizbQuarter": 130,
        "sajda": false
      },
      {
        "number": 2532,
        "text": "ٱلَّذِینَ یَخۡشَوۡنَ رَبَّهُم بِٱلۡغَیۡبِ وَهُم مِّنَ ٱلسَّاعَةِ مُشۡفِقُونَ\n",
        "surah": {
          "number": 21,
          "name": "سُورَةُ الأَنبِيَاءِ",
