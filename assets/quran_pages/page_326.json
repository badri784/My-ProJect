        "sajda": false
      },
      {
        "number": 2538,
        "text": "قَالُوۤا۟ أَجِئۡتَنَا بِٱلۡحَقِّ أَمۡ أَنتَ مِنَ ٱللَّـٰعِبِینَ\n",
