        "sajda": false
      },
      {
        "number": 2534,
        "text": "۞ وَلَقَدۡ ءَاتَیۡنَاۤ إِبۡرَ ٰ⁠هِیمَ رُشۡدَهُۥ مِن قَبۡلُ وَكُنَّا بِهِۦ عَـٰلِمِینَ\n",
        "surah": {
          "number": 21,
          "name": "سُورَةُ الأَنبِيَاءِ",
          "englishName": "Al-Anbiyaa",
          "englishNameTranslation": "The Prophets",
