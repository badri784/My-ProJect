        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5438,
        "text": "وَٱللَّهُ جَعَلَ لَكُمُ ٱلۡأَرۡضَ بِسَاطࣰا\n",
        "surah": {
          "number": 71,
