        "ruku": 504,
        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5436,
        "text": "وَٱللَّهُ أَنۢبَتَكُم مِّنَ ٱلۡأَرۡضِ نَبَاتࣰا\n",
        "surah": {
          "number": 71,
