        "sajda": false
      },
      {
        "number": 5440,
        "text": "قَالَ نُوحࣱ رَّبِّ إِنَّهُمۡ عَصَوۡنِی وَٱتَّبَعُوا۟ مَن لَّمۡ یَزِدۡهُ مَالُهُۥ وَوَلَدُهُۥۤ إِلَّا خَسَارࣰا\n",
        "surah": {
          "number": 71,
          "name": "سُورَةُ نُوحٍ",
