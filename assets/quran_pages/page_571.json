        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5434,
        "text": "أَلَمۡ تَرَوۡا۟ كَیۡفَ خَلَقَ ٱللَّهُ سَبۡعَ سَمَـٰوَ ٰ⁠تࣲ طِبَاقࣰا\n",
        "surah": {
          "number": 71,
          "name": "سُورَةُ نُوحٍ",
          "englishName": "Nooh",
