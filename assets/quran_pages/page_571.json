        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5435,
        "text": "وَجَعَلَ ٱلۡقَمَرَ فِیهِنَّ نُورࣰا وَجَعَلَ ٱلشَّمۡسَ سِرَاجࣰا\n",
        "surah": {
          "number": 71,
