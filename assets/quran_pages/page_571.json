        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5433,
        "text": "وَقَدۡ خَلَقَكُمۡ أَطۡوَارًا\n",
        "surah": {
          "number": 71,
          "name": "سُورَةُ نُوحٍ",
