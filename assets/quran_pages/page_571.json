        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5432,
        "text": "مَّا لَكُمۡ لَا تَرۡجُونَ لِلَّهِ وَقَارࣰا\n",
        "surah": {
          "number": 71,
