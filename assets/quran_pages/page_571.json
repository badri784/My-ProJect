        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5442,
        "text": "وَقَالُوا۟ لَا تَذَرُنَّ ءَالِهَتَكُمۡ وَلَا تَذَرُنَّ وَدࣰّا وَلَا سُوَاعࣰا وَلَا یَغُوثَ وَیَعُوقَ وَنَسۡرࣰا\n",
        "surah": {
          "number": 71,
