        "hizbQuarter": 228,
        "sajda": false
      },
      {
        "number": 5437,
        "text": "ثُمَّ یُعِیدُكُمۡ فِیهَا وَیُخۡرِجُكُمۡ إِخۡرَاجࣰا\n",
        "surah": {
          "number": 71,
