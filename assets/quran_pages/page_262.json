        "sajda": false
      },
      {
        "number": 1806,
        "text": "وَمَاۤ أَهۡلَكۡنَا مِن قَرۡیَةٍ إِلَّا وَلَهَا كِتَابࣱ مَّعۡلُومࣱ\n",
        "surah": {
