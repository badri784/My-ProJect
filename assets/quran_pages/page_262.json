        "sajda": false
      },
      {
        "number": 1808,
        "text": "وَقَالُوا۟ یَـٰۤأَیُّهَا ٱلَّذِی نُزِّلَ عَلَیۡهِ ٱلذِّكۡرُ إِنَّكَ لَمَجۡنُونࣱ\n",
        "surah": {
