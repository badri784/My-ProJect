        "sajda": false
      },
      {
        "number": 1807,
        "text": "مَّا تَسۡبِقُ مِنۡ أُمَّةٍ أَجَلَهَا وَمَا یَسۡتَـٔۡخِرُونَ\n",
        "surah": {
          "number": 15,
