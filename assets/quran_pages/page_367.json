        "page": 367,
        "ruku": 316,
        "hizbQuarter": 147,
        "sajda": false
      },
      {
        "number": 2938,
        "text": "فَقَدۡ كَذَّبُوا۟ فَسَیَأۡتِیهِمۡ أَنۢبَـٰۤؤُا۟ مَا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
          "englishName": "Ash-Shu'araa",
          "englishNameTranslation": "The Poets",
          "revelationType": "Meccan",
          "numberOfAyahs": 227
        },
        "numberInSurah": 6,
