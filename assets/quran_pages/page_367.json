        "sajda": false
      },
      {
        "number": 2947,
        "text": "قَالَ كَلَّاۖ فَٱذۡهَبَا بِـَٔایَـٰتِنَاۤۖ إِنَّا مَعَكُم مُّسۡتَمِعُونَ\n",
        "surah": {
          "number": 26,
