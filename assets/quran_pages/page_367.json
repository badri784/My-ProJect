        "hizbQuarter": 147,
        "sajda": false
      },
      {
        "number": 2935,
        "text": "لَعَلَّكَ بَـٰخِعࣱ نَّفۡسَكَ أَلَّا یَكُونُوا۟ مُؤۡمِنِینَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
          "englishName": "Ash-Shu'araa",
          "englishNameTranslation": "The Poets",
          "revelationType": "Meccan",
          "numberOfAyahs": 227
        },
        "numberInSurah": 3,
        "juz": 19,
        "manzil": 5,
        "page": 367,
        "ruku": 316,
        "hizbQuarter": 147,
        "sajda": false
      },
      {
        "number": 2936,
        "text": "إِن نَّشَأۡ نُنَزِّلۡ عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ ءَایَةࣰ فَظَلَّتۡ أَعۡنَـٰقُهُمۡ لَهَا خَـٰضِعِینَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
          "englishName": "Ash-Shu'araa",
          "englishNameTranslation": "The Poets",
          "revelationType": "Meccan",
          "numberOfAyahs": 227
        },
        "numberInSurah": 4,
        "juz": 19,
        "manzil": 5,
        "page": 367,
        "ruku": 316,
        "hizbQuarter": 147,
        "sajda": false
      },
      {
        "number": 2937,
        "text": "وَمَا یَأۡتِیهِم مِّن ذِكۡرࣲ مِّنَ ٱلرَّحۡمَـٰنِ مُحۡدَثٍ إِلَّا كَانُوا۟ عَنۡهُ مُعۡرِضِینَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
          "englishName": "Ash-Shu'araa",
          "englishNameTranslation": "The Poets",
          "revelationType": "Meccan",
