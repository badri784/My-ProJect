        "sajda": false
      },
      {
        "number": 2943,
        "text": "قَوۡمَ فِرۡعَوۡنَۚ أَلَا یَتَّقُونَ\n",
        "surah": {
          "number": 26,
          "name": "سُورَةُ الشُّعَرَاءِ",
          "englishName": "Ash-Shu'araa",
