        "hizbQuarter": 147,
        "sajda": false
      },
      {
        "number": 2944,
        "text": "قَالَ رَبِّ إِنِّیۤ أَخَافُ أَن یُكَذِّبُونِ\n",
        "surah": {
          "number": 26,
